// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  category    String   @default("Writing")
  tags        String   @default("")
  coverColor  String   @default("#1c1917")
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  readingTime Int      @default(3)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String
  description String
  year        String
  role        String
  category    String   @default("Selected Work")
  client      String   @default("")
  url         String   @default("")
  accent      String   @default("#1c1917")
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
